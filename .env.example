# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# VDT Slack Bot — 환경변수 설정
# 이 파일을 .env 로 복사한 후 값을 채워주세요
# cp .env.example .env
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── Slack ──
# Slack App 생성: https://api.slack.com/apps
# Bot Token Scopes 필요: chat:write, commands
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...

# ── Jira ──
JIRA_DOMAIN=bagelcode.atlassian.net
JIRA_EMAIL=your.name@bagelcode.com
JIRA_TOKEN=...   # https://id.atlassian.com/manage-profile/security/api-tokens

# ── Anthropic ──
ANTHROPIC_API_KEY=sk-ant-...
# 내부 aiproxy 사용 시 아래 주석 해제
# ANTHROPIC_BASE_URL=https://aiproxy.backoffice.bagelgames.com

# ── Google Drive (base64 인코딩된 google_token.json) ──
# 발급 방법: python3 skills/vdt/vdt-auth.py 실행 후
#   base64 -i ~/.bagelcode/google_token.json | tr -d '\n'
GOOGLE_TOKEN_JSON=...

# ── GitHub Pages 배포 ──
# Fine-grained token: Contents(read/write) 권한 필요
GITHUB_TOKEN=ghp_...
PAGES_REPO=bumsinkim-cyber/vdt-reports
PAGES_BASE_URL=https://bumsinkim-cyber.github.io/vdt-reports

# ── 보고서 수신 Slack 채널 ID ──
REPORT_CHANNEL=C0AQTSRRFHC
